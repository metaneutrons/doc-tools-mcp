{
  "name": "@metaneutrons/doc-tools-mcp",
  "version": "0.3.0",
  "description": "MCP server for managing pandoc/CSL-YAML bibliographies",
  "main": "dist/index.js",
  "bin": {
    "doc-tools-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metaneutrons/doc-tools-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/metaneutrons/doc-tools-mcp/issues"
  },
  "homepage": "https://github.com/metaneutrons/doc-tools-mcp#readme",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "mcp",
    "bibliography",
    "csl",
    "yaml",
    "pandoc",
    "citations"
  ],
  "author": {
    "name": "Fabian Schmieder"
  },
  "license": "GPL-3.0",
  "type": "module",
  "lint-staged": {
    "package.json": [
      "npm audit --audit-level=moderate"
    ],
    "*.ts": [
      "eslint --fix",
      "vitest related --run"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/node": "^25.3.5",
    "js-yaml": "^4.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
